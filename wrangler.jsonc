{
  // Cloudflare Workers 项目名
  "name": "blog",
  "compatibility_date": "2025-06-19",
  // Hexo 生成的静态文件目录，Cloudflare 直接托管这里的内容
  "assets": {
    "directory": "./public"
  },
  // 自定义域名（zone 已在本账号的 Cloudflare 上），部署时自动绑定 DNS + SSL
  "routes": [
    { "pattern": "singularities.cc", "custom_domain": true }
  ]
}
